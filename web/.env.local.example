# Copy to .env.local — never commit real secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Apply SQL in web/supabase/migrations/ so `usage_stats` exists (free-tier daily limits; paid unlimited).

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_GUARD_MONTHLY=price_...

# Subscription Price IDs (Dashboard → Products → each Price → copy `price_...`).
# Webhook/checkout map these to profiles.plan: starter | business | enterprise.
# Search limits: starter 25/mo, business 200/mo, enterprise unlimited (see lib/config/plans.js).
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
# One-time Event Pack (Checkout mode=payment) — does not set subscription tier.
STRIPE_PRICE_EVENT_PACK=price_...

# DCA API (California BSIS verification)
DCA_APP_ID=your-dca-app-id
DCA_APP_KEY=your-dca-app-key
# Optional: faster GET-first license lookup timeout (ms) before falling back to POST agile search
# DCA_LICENSE_GET_TIMEOUT_MS=12000
# Cache "not found" license lookups shorter than hits (ms); default 300000 (5m)
# VERIFY_CACHE_NOT_FOUND_MS=300000

# Site URL (must match what you set in Supabase → Authentication → URL Configuration)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In Supabase Dashboard, add these to Redirect URLs (Authentication → URL Configuration):
#   http://localhost:3000/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback
# Enable "Confirm email" under Authentication → Providers → Email if you want signup verification.
#
# Branded HTML for auth emails (reset + confirm): copy from web/supabase/email-templates/*.html into
# Supabase → Authentication → Email Templates (set subjects as noted in each file’s comment).

# Cron secret (for securing cron API routes)
CRON_SECRET=replace_with_random_secret

# API rate limits (requests per window; middleware). Omit to use defaults.
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_VERIFY_BATCH_PER_MIN=12
# RATE_LIMIT_SCRAPER_PER_MIN=18
# RATE_LIMIT_SEARCH_PUBLIC_PER_MIN=28
# RATE_LIMIT_VERIFY_PER_MIN=45
# RATE_LIMIT_SEARCH_AUTH_PER_MIN=40
# RATE_LIMIT_BILLING_PER_MIN=60
# RATE_LIMIT_DEFAULT_PER_MIN=100

# Optional
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
